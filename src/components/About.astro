---
import "@styles/about.css";

// Данные FAQ
const faq = [
  {
    q: "Как записаться на СПА-процедуру?",
    a: "Напишите нам в Telegram/What’s App или позвоните — подберём программу и закрепим время. Перед визитом пришлём напоминание и маршрут.",
  },
  {
    q: "Что взять с собой?",
    a: "Ничего не требуется. У нас есть одноразовые принадлежности, тёплые полотенца, душ и напитки.",
  },
];
---

<div class="about">
  <!-- ===== HERO ===== -->
  <section class="about-hero" id="about" aria-labelledby="about-title">
    <div class="about-hero__glow" aria-hidden="true"></div>

    <!-- ===== INTRO ===== -->
    <section class="about-intro" aria-labelledby="about-intro-title">
      <div class="container about-grid">
        <div class="about-col about-col--text fade-up">
          <h2 id="about-intro-title">О нас</h2>
          <p>Здравствуйте, дорогие друзья!</p>
          <p>
            Для каждого гостя предусмотрены чай или кофе, душ, махровые полотенца, одноразовые
            тапочки и аромамасла
          </p>
        </div>

        <ul class="about-col about-col--perks about-perks fade-up" aria-label="Преимущества студии">
          <li>
            <span class="about-perks__icon" aria-hidden="true">
              <!-- 🕯️ -->
              <svg viewBox="0 0 24 24" fill="none" focusable="false" aria-hidden="true">
                <path
                  d="M12 2a2 2 0 0 0-2 2v1a2 2 0 0 0 4 0V4a2 2 0 0 0-2-2Z"
                  stroke="currentColor"
                  stroke-width="1.6"></path>
                <rect
                  x="8"
                  y="8"
                  width="8"
                  height="12"
                  rx="2"
                  stroke="currentColor"
                  stroke-width="1.6"></rect>
              </svg>
            </span>
            Комфортная и уютная атмосфера
          </li>
        </ul>
      </div>
    </section>

    <!-- ===== PROCESS ===== -->
    <section class="about-process" aria-labelledby="about-process-title">
      <div class="about-process__glow" aria-hidden="true"></div>
      <div class="container">
        <div class="about-process__head">
          <span class="about-process__tag fade-up">Путь гостя</span>
          <h2 class="fade-up" id="about-process-title" style="animation-delay:.04s">
            Как проходит визит
          </h2>
          <p class="about-process__intro fade-up" style="animation-delay:.08s">
            Наши ритуалы выстроены так, чтобы каждая минута была наполнена заботой.
          </p>
        </div>

        <ol class="about-steps" aria-label="Этапы визита">
          <li class="about-steps__item fade-up">
            <div class="about-steps__header">
              <span class="about-step" aria-hidden="true">1</span>
              <h3>Запись любым способом</h3>
            </div>
            <p>
              Свяжитесь с нами по звонку, через сообщения или онлайн. Мы сможем предложить для вас
              удобную дату и проконсультируем вас.
            </p>
          </li>
          <!-- <li class="about-steps__item fade-up" style="animation-delay:.04s">
            <div class="about-steps__header">
              <span class="about-step" aria-hidden="true">2</span>
              <h3>Путь до студии</h3>
            </div>
            <p>
              Мы находимся в центре города, поэтому до нас легко добраться из любой точки. На данный
              момент в вашем распоряжении 3 премиальных салона массажа и СПА-услуг. Если вы на
              автомобиле, у нас присутствует стоянка во дворе студии.
            </p>
          </li> -->
          <!-- <li class="about-steps__item fade-up" style="animation-delay:.08s">
            <div class="about-steps__header">
              <span class="about-step" aria-hidden="true">2</span>
              <h3>Обряд подготовки</h3>
            </div>
            <p>
              Начальное знакомство с мастером и студией, а также консультация от профессионала по
              практическим вопросам. У нас имеются комфортный душ и ароматные благоухания.
            </p>
          </li> -->
          <li class="about-steps__item fade-up" style="animation-delay:.12s">
            <div class="about-steps__header">
              <span class="about-step" aria-hidden="true">2</span>
              <h3>СПА-процедуры</h3>
            </div>
            <p>Профессиональные техники исполнения расслабляют и тонизируют мышцы.</p>
          </li>
          <!-- <li class="about-steps__item fade-up" style="animation-delay:.16s">
            <div class="about-steps__header">
              <span class="about-step" aria-hidden="true">4</span>
              <h3>Церемония завершения</h3>
            </div>
            <p>Мы предлагаем на выбор чай или кофе, а также восточные сладости.</p>
          </li> -->
        </ol>

        <!-- <figure class="about-process__quote fade-up" style="animation-delay:.24s">
          <blockquote>
            «Попробуй <strong>"Гармония СПА"</strong> однажды — и ты захочешь вернуться снова!»
          </blockquote>
        </figure> -->
      </div>
    </section>

    <!-- ===== FAQ ===== -->
    <section class="about-faq" aria-labelledby="about-faq-title">
      <div class="container">
        <h2 class="fade-up" id="about-faq-title">Частые вопросы</h2>
        <div class="about-faq__list">
          {
            faq.map((item) => (
              <details class="about-faq__item fade-up">
                <summary>{item.q}</summary>
                <div class="about-faq__ans">{item.a}</div>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section class="about-cta" aria-labelledby="about-cta-title">
      <div class="container about-cta__box">
        <div>
          <h2 id="about-cta-title">Готовы выбрать программу?</h2>
          <p class="about-cta__sub">Поможем определиться и найдём удобное время сегодня.</p>
        </div>
        <a class="about-btn" href="#booking" aria-label="Записаться"> Записаться </a>
      </div>
    </section>
  </section>
</div>
