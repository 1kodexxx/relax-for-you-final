---
import { getCollection } from "astro:content";
import "@/styles/booking-modal.css";

/** === ДАННЫЕ ИЗ КОЛЛЕКЦИЙ === */
const massages = await getCollection("massages");
const masters = await getCollection("masters");

/** Порядок и подписи категорий */
const categoryOrder = new Map([
  ["spa", 1],
  ["zones", 2],
]);
const categoryLabels: Record<string, string> = {
  spa: "МАССАЖ",
  zones: "SPA-ПРОГРАММЫ",
};

/** Группировка программ по категориям */
type Option = { value: string; label: string; order: number };
type Group = { key: string; title: string; order: number; options: Option[] };

const groupMap = new Map<string, Group>();
for (const entry of massages) {
  const d = entry.data as any;
  const key = d.category ?? "spa";

  if (!groupMap.has(key)) {
    groupMap.set(key, {
      key,
      title: d.categoryTitle ?? categoryLabels[key] ?? key,
      order: categoryOrder.get(key) ?? Number.MAX_SAFE_INTEGER,
      options: [],
    });
  }

  const g = groupMap.get(key)!;
  g.options.push({
    value: d.title,
    label: d.duration ? `${d.title} · ${d.duration}` : d.title,
    order: typeof d.order === "number" ? d.order : Number.MAX_SAFE_INTEGER,
  });
}

const programGroups = [...groupMap.values()]
  .map((g) => ({ ...g, options: g.options.sort((a, b) => a.order - b.order) }))
  .sort((a, b) => a.order - b.order);

const defaultProgram = programGroups[0]?.options[0]?.value ?? "";
const defaultMaster = masters[0]?.data.name ?? "";

/** Текст в шапке модалки можно переопределить через props */
const {
  modalTitle = "Онлайн-запись",
  modalSubtitle = "Укажите подходящую дату и время для сеанса — мы свяжемся с вами в ближайшее время.",
} = Astro.props;
---

<section
  id="booking"
  class="booking-modal"
  data-booking-modal
  aria-hidden="true"
  role="presentation"
>
  <div class="booking-modal__backdrop" data-backdrop></div>

  <div
    class="booking-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="booking-modal-title"
  >
    <button class="booking-modal__close" type="button" data-close aria-label="Закрыть">×</button>

    <header class="booking-modal__header">
      <p class="booking-modal__eyebrow">Relax For You</p>
      <h2 id="booking-modal-title" class="booking-modal__title">{modalTitle}</h2>
      <p class="booking-modal__subtitle">{modalSubtitle}</p>
    </header>

    <form class="booking-modal__form" data-form novalidate>
      <!-- 🐝 honeypot (боты заполняют — мы игнорим) -->
      <input
        type="text"
        name="company"
        aria-hidden="true"
        tabindex="-1"
        autocomplete="off"
        style="position:absolute;left:-9999px;opacity:0;"
      />

      <!-- Имя -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="booking-name">Имя*</label>
        <input
          id="booking-name"
          name="name"
          class="booking-modal__input"
          type="text"
          placeholder="Как к вам обращаться?"
          required
          autocomplete="name"
        />
      </div>

      <!-- Телефон -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="booking-phone">Телефон*</label>
        <input
          id="booking-phone"
          name="phone"
          class="booking-modal__input"
          type="tel"
          placeholder="+7..."
          required
          autocomplete="tel"
          inputmode="tel"
        />
      </div>

      <!-- Программа -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="booking-program">Программа массажа*</label>
        <select id="booking-program" name="selected_program" class="booking-modal__select" required>
          {
            programGroups.map((group) => (
              <optgroup label={group.title}>
                {group.options.map((o) => (
                  <option value={o.value} selected={o.value === defaultProgram}>
                    {o.label}
                  </option>
                ))}
              </optgroup>
            ))
          }
        </select>
      </div>

      <div class="booking-modal__row">
        <!-- Дата -->
        <div class="booking-modal__field">
          <label class="booking-modal__label" for="booking-date">Дата*</label>
          <input id="booking-date" name="date" class="booking-modal__input" type="date" required />
        </div>

        <!-- Время -->
        <div class="booking-modal__field">
          <label class="booking-modal__label" for="booking-time">Время*</label>
          <select id="booking-time" name="time" class="booking-modal__select" required>
            {
              // Время с 10:00 до 20:00 включительно
              Array.from({ length: 11 }, (_, i) => {
                const hour = 10 + i; // 10..20
                const formatted = String(hour).padStart(2, "0") + ":00";
                return <option value={formatted}>{formatted}</option>;
              })
            }
          </select>
        </div>
      </div>

      <!-- Мастер -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="booking-master">Мастер</label>
        <select id="booking-master" name="selected_master" class="booking-modal__select">
          {
            masters.map(({ data }: { data: any }) => (
              <option value={data.name} selected={data.name === defaultMaster}>
                {data.name}
              </option>
            ))
          }
        </select>
      </div>

      <!-- Комментарий -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="booking-message">Комментарий</label>
        <textarea
          id="booking-message"
          name="message"
          class="booking-modal__textarea"
          rows={4}
          placeholder="Укажите ваши пожелания или предпочтения по деталям записи"></textarea>
      </div>

      <!-- Кнопки -->
      <div class="booking-modal__field">
        <button class="booking-modal__submit" type="submit" data-submit>Отправить заявку</button>
      </div>

      <p>Или свяжитесь с нами по звонку или через сообщения</p>

      <div class="booking-modal__actions">
        <a href="tel:+79533025946" class="booking-modal__alt-btn">📞 Связаться по звонку</a>
        <a href="https://t.me/IrinaMassage79" class="booking-modal__alt-btn">
          💬 Связаться через сообщения
        </a>
      </div>

      <p class="booking-modal__policy">
        Отправляя форму, вы подтверждаете своё согласие на обработку персональных данных, в том
        числе на их передачу в мессенджер Telegram и иные используемые сервисы, в соответствии с
        <a href="/privacy" class="booking-modal__policy-link">
          Политикой конфиденциальности Relax For You
        </a>.
      </p>

      <div class="booking-modal__feedback" data-feedback role="status" aria-live="polite" hidden>
      </div>
    </form>

    <div class="booking-modal__overlay-message" data-overlay-message hidden></div>
  </div>
</section>

<!-- ================== JS ================== -->
<script is:inline>
  (() => {
    const WEBHOOK_URL = "https://eoiolinmefd6i6s.m.pipedream.net";

    const modal = document.querySelector("[data-booking-modal]");
    if (!modal) return;

    const form = modal.querySelector("[data-form]");
    const feedback = modal.querySelector("[data-feedback]");
    const overlayMsg = modal.querySelector("[data-overlay-message]");
    const submitBtn = modal.querySelector("[data-submit]");
    const closeBtns = modal.querySelectorAll("[data-close]");
    const backdrop = modal.querySelector("[data-backdrop]");
    const firstField = modal.querySelector("#booking-name");
    const programSelect = modal.querySelector("#booking-program");
    const masterSelect = modal.querySelector("#booking-master");
    const phoneInput = modal.querySelector("#booking-phone");
    const dateInput = modal.querySelector("#booking-date");
    const defaultSubmitText = submitBtn?.textContent || "";

    // === Центрированные overlay-сообщения ===
    const showOverlayMessage = (msg, type = "success", duration = 2600) => {
      if (!overlayMsg) return;
      overlayMsg.textContent = msg;
      overlayMsg.classList.remove("is-success", "is-error", "is-visible");

      if (type === "success") overlayMsg.classList.add("is-success");
      if (type === "error") overlayMsg.classList.add("is-error");

      overlayMsg.hidden = false;
      requestAnimationFrame(() => overlayMsg.classList.add("is-visible"));

      setTimeout(() => {
        overlayMsg.classList.remove("is-visible");
        overlayMsg.hidden = true;
      }, duration);
    };

    // === Текстовый фидбек под формой (доп. слой поверх overlay, можно использовать при желании) ===
    const setFeedback = (message = "", type = "") => {
      if (!feedback) return;
      feedback.textContent = message;
      feedback.classList.remove("is-success", "is-error");
      if (!message) {
        feedback.hidden = true;
        return;
      }
      if (type === "success") feedback.classList.add("is-success");
      if (type === "error") feedback.classList.add("is-error");
      feedback.hidden = false;
    };

    // === Ограничения даты: не раньше сегодня и не дальше, чем через 3 месяца ===
    if (dateInput instanceof HTMLInputElement) {
      const toIso = (d) => {
        const copy = new Date(d.getTime());
        copy.setHours(0, 0, 0, 0);
        return copy.toISOString().split("T")[0];
      };

      const today = new Date();
      const maxDate = new Date();
      maxDate.setMonth(maxDate.getMonth() + 3);

      dateInput.min = toIso(today);
      dateInput.max = toIso(maxDate);
    }

    // === localStorage: запоминаем имя и телефон ===
    try {
      const savedName = localStorage.getItem("rfy_name");
      const savedPhone = localStorage.getItem("rfy_phone");

      const nameInput = modal.querySelector("#booking-name");
      if (savedName && nameInput instanceof HTMLInputElement) {
        nameInput.value = savedName;
      }
      if (savedPhone && phoneInput instanceof HTMLInputElement) {
        phoneInput.value = savedPhone;
      }

      if (nameInput instanceof HTMLInputElement) {
        nameInput.addEventListener("input", (e) =>
          localStorage.setItem("rfy_name", e.target.value || "")
        );
      }
      if (phoneInput instanceof HTMLInputElement) {
        phoneInput.addEventListener("input", (e) =>
          localStorage.setItem("rfy_phone", e.target.value || "")
        );
      }
    } catch (_) {
      // localStorage может быть недоступен в приватных режимах — просто молча игнорируем
    }

    const lockScroll = () => {
      document.body.style.overflow = "hidden";
    };

    const unlockScroll = () => {
      document.body.style.overflow = "";
    };

    const open = (dataset = {}) => {
      modal.setAttribute("data-open", "true");
      modal.setAttribute("aria-hidden", "false");
      lockScroll();

      const { program, master } = dataset;
      if (program && programSelect instanceof HTMLSelectElement) {
        programSelect.value = program;
      }
      if (master && masterSelect instanceof HTMLSelectElement) {
        masterSelect.value = master;
      }

      requestAnimationFrame(() => {
        if (firstField instanceof HTMLElement) {
          firstField.focus();
        }
      });

      // Чистим hash, если переход был по #booking
      if (location.hash === "#booking") {
        history.replaceState(null, "", location.pathname + location.search);
      }
    };

    const close = () => {
      modal.setAttribute("data-open", "false");
      modal.setAttribute("aria-hidden", "true");
      unlockScroll();
      setFeedback("", "");
      if (form instanceof HTMLFormElement) {
        form.reset();
      }
    };

    // ✅ Делегирование на документе — ловим любые триггеры, в т.ч. динамические
    document.addEventListener("click", (e) => {
      const target = e.target;
      if (!target || !target.closest) return;

      const trigger = target.closest('a[href="#booking"], [data-booking-trigger]');
      if (!trigger) return;

      e.preventDefault();
      open(trigger.dataset || {});
    });

    closeBtns.forEach((b) =>
      b.addEventListener("click", () => {
        close();
      })
    );

    if (backdrop) {
      backdrop.addEventListener("click", close);
    }

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.getAttribute("data-open") === "true") {
        close();
      }
    });

    // Если пользователь зашёл сразу с #booking в урле
    if (location.hash === "#booking") {
      open();
    }

    // === Маска телефона (мягкая нормализация) ===
    function normalizePhone(raw) {
      const d = String(raw || "").replace(/\D/g, "");
      if (!d) return "";
      if (d.length === 10) {
        // 9xx xxx-xx-xx
        return `+7 (${d.slice(0, 3)}) ${d.slice(3, 6)}-${d.slice(6, 8)}-${d.slice(8, 10)}`;
      }
      if (d.length >= 11) {
        // 7 9xx xxx-xx-xx
        return `+7 (${d.slice(1, 4)}) ${d.slice(4, 7)}-${d.slice(7, 9)}-${d.slice(9, 11)}`;
      }
      return raw;
    }

    if (phoneInput instanceof HTMLInputElement) {
      phoneInput.addEventListener("blur", () => {
        phoneInput.value = normalizePhone(phoneInput.value);
      });
    }

    // === Отправка формы ===
    if (form instanceof HTMLFormElement) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const fd = new FormData(form);
        const payload = Object.fromEntries(fd.entries());

        // honeypot: если поле company заполнено — бот, выходим
        if (payload.company) return;

        const requiredFields = {
          name: "Имя",
          phone: "Телефон",
          selected_program: "Программа массажа",
          date: "Дата",
          time: "Время",
        };

        form
          .querySelectorAll(".booking-modal__input, .booking-modal__select")
          .forEach((el) => el.classList.remove("is-error"));

        const missing = Object.entries(requiredFields)
          .filter(([key]) => !payload[key] || String(payload[key]).trim() === "")
          .map(([_, label]) => label);

        if (missing.length > 0) {
          Object.keys(requiredFields).forEach((key) => {
            const el = form.querySelector(`[name="${key}"]`);
            if (!payload[key] || String(payload[key]).trim() === "") {
              el?.classList.add("is-error");
            }
          });

          showOverlayMessage(`Заполните: ${missing.join(", ")}.`, "error", 2800);
          setFeedback(`Заполните: ${missing.join(", ")}.`, "error");
          return;
        }

        try {
          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.setAttribute("disabled", "true");
            submitBtn.textContent = "Отправляем…";
          }

          await new Promise((r) => setTimeout(r, 400 + Math.random() * 300));

          const res = await fetch(WEBHOOK_URL, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              name: payload.name,
              phone: payload.phone,
              program: payload.selected_program,
              date: payload.date,
              time: payload.time,
              master: payload.selected_master || "",
              message: payload.message || "",
              channel: "Сайт Relax For You",
              site: "https://relaxmassage51.ru",
            }),
          });

          if (res.ok) {
            showOverlayMessage(
              "✅ Заявка успешно отправлена! Мы скоро свяжемся 💗",
              "success",
              2600
            );
            setFeedback("Заявка успешно отправлена! Мы скоро свяжемся.", "success");
            form.reset();
            setTimeout(close, 2800);
          } else {
            showOverlayMessage("⚠️ Ошибка при отправке. Попробуйте позже.", "error", 2800);
            setFeedback("Ошибка при отправке. Попробуйте позже.", "error");
          }
        } catch (err) {
          console.error(err);
          showOverlayMessage("❌ Ошибка соединения. Проверьте интернет.", "error", 2800);
          setFeedback("Ошибка соединения. Проверьте интернет.", "error");
        } finally {
          if (submitBtn instanceof HTMLButtonElement) {
            submitBtn.removeAttribute("disabled");
            submitBtn.textContent = defaultSubmitText;
          }
        }
      });
    }
  })();
</script>
