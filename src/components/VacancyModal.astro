---
import "@/styles/booking-modal.css";

/** Заголовки можно переопределять через props */
const {
  modalTitle = "Отклик на вакансию",
  modalSubtitle = "Оставьте свои контактные данные, и наш менеджер свяжется с вами для обсуждения деталей сотрудничества 💼",
} = Astro.props;
---

<section
  id="vacancy"
  class="booking-modal"
  data-vacancy-modal
  aria-hidden="true"
  role="presentation"
>
  <div class="booking-modal__backdrop" data-backdrop></div>

  <div
    class="booking-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="vacancy-modal-title"
  >
    <button class="booking-modal__close" type="button" data-close aria-label="Закрыть">×</button>

    <header class="booking-modal__header">
      <p class="booking-modal__eyebrow">Гармония СПА</p>
      <h2 id="vacancy-modal-title" class="booking-modal__title">{modalTitle}</h2>
      <p class="booking-modal__subtitle">{modalSubtitle}</p>
    </header>

    <form class="booking-modal__form" data-form novalidate>
      <!-- 🐝 honeypot -->
      <input
        type="text"
        name="company"
        aria-hidden="true"
        tabindex="-1"
        autocomplete="off"
        style="position:absolute;left:-9999px;opacity:0;"
      />

      <!-- Имя -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="vacancy-name">Имя*</label>
        <input
          id="vacancy-name"
          name="name"
          class="booking-modal__input"
          type="text"
          placeholder="Ваше имя"
          required
          autocomplete="name"
        />
      </div>

      <!-- Телефон -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="vacancy-phone">Телефон*</label>
        <input
          id="vacancy-phone"
          name="phone"
          class="booking-modal__input"
          type="tel"
          placeholder="+7..."
          required
          autocomplete="tel"
          inputmode="tel"
        />
      </div>

      <!-- Вакансия -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="vacancy-role">Интересующая должность*</label>
        <select id="vacancy-role" name="role" class="booking-modal__select" required>
          <option value="">Выберите вакансию</option>
          <option value="Администратор (менеджер)">Администратор (менеджер)</option>
          <option value="Мастер массажа и SPA-процедур">Мастер массажа и SPA-процедур</option>
          <option value="Управляющий руководитель">Управляющий руководитель</option>
        </select>
      </div>

      <!-- Комментарий -->
      <div class="booking-modal__field">
        <label class="booking-modal__label" for="vacancy-message">Сообщение</label>
        <textarea
          id="vacancy-message"
          name="message"
          class="booking-modal__textarea"
          rows={4}
          placeholder="Расскажите о себе или задайте вопрос менеджеру..."></textarea>
      </div>

      <div class="booking-modal__field">
        <button class="booking-modal__submit" type="submit" data-submit>Отправить отклик</button>
      </div>

      <p class="booking-modal__policy">
        Отправляя заявку, вы подтверждаете своё согласие на обработку персональных данных, в том
        числе на их передачу в мессенджер Telegram и иные используемые сервисы, в соответствии с
        <a href="/privacy" class="booking-modal__policy-link">
          Политикой конфиденциальности Гармонии СПА
        </a>.
      </p>

      <div class="booking-modal__feedback" data-feedback role="status" aria-live="polite" hidden>
      </div>
    </form>

    <div class="booking-modal__overlay-message" data-overlay-message hidden></div>
  </div>
</section>

<!-- ================== JS ================== -->
<script is:inline>
  (() => {
    const WEBHOOK_URL = "https://eoiolinmefd6i6s.m.pipedream.net"; // тот же вебхук

    const modal = document.querySelector("[data-vacancy-modal]");
    if (!modal) return;

    const form = modal.querySelector("[data-form]");
    const feedback = modal.querySelector("[data-feedback]");
    const overlayMsg = modal.querySelector("[data-overlay-message]");
    const submitBtn = modal.querySelector("[data-submit]");
    const closeBtns = modal.querySelectorAll("[data-close]");
    const backdrop = modal.querySelector("[data-backdrop]");
    const triggers = document.querySelectorAll('a[href="#vacancy"], [data-vacancy-trigger]');
    const firstField = modal.querySelector("#vacancy-name");
    const phoneInput = modal.querySelector("#vacancy-phone");
    const defaultSubmitText = submitBtn?.textContent || "";

    const lockScroll = () => {
      document.body.style.overflow = "hidden";
    };

    const unlockScroll = () => {
      document.body.style.overflow = "";
    };

    const showOverlayMessage = (msg, type = "success", duration = 2500) => {
      if (!overlayMsg) return;
      overlayMsg.textContent = msg;
      overlayMsg.classList.remove("is-success", "is-error", "is-visible");

      if (type === "success") overlayMsg.classList.add("is-success");
      if (type === "error") overlayMsg.classList.add("is-error");

      overlayMsg.hidden = false;
      requestAnimationFrame(() => overlayMsg.classList.add("is-visible"));
      setTimeout(() => {
        overlayMsg.classList.remove("is-visible");
        overlayMsg.hidden = true;
      }, duration);
    };

    const setFeedback = (message = "", type = "") => {
      if (!feedback) return;
      feedback.textContent = message;
      feedback.classList.remove("is-success", "is-error");
      if (!message) {
        feedback.hidden = true;
        return;
      }
      if (type === "success") feedback.classList.add("is-success");
      if (type === "error") feedback.classList.add("is-error");
      feedback.hidden = false;
    };

    const open = () => {
      modal.setAttribute("data-open", "true");
      modal.setAttribute("aria-hidden", "false");
      lockScroll();
      requestAnimationFrame(() => firstField?.focus());
      if (location.hash === "#vacancy") {
        history.replaceState(null, "", location.pathname + location.search);
      }
    };

    const close = () => {
      modal.setAttribute("data-open", "false");
      modal.setAttribute("aria-hidden", "true");
      unlockScroll();
      setFeedback("", "");
      form instanceof HTMLFormElement && form.reset();
    };

    triggers.forEach((t) =>
      t.addEventListener("click", (e) => {
        e.preventDefault();
        open();
      })
    );
    closeBtns.forEach((b) => b.addEventListener("click", close));
    backdrop?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && modal.getAttribute("data-open") === "true") close();
    });

    if (location.hash === "#vacancy") open();

    // === Нормализация телефона ===
    function normalizePhone(raw) {
      const d = String(raw || "").replace(/\D/g, "");
      if (!d) return "";
      if (d.length === 10)
        return (
          "+7 (" + d.slice(0, 3) + ") " + d.slice(3, 6) + "-" + d.slice(6, 8) + "-" + d.slice(8, 10)
        );
      if (d.length >= 11)
        return (
          "+7 (" + d.slice(1, 4) + ") " + d.slice(4, 7) + "-" + d.slice(7, 9) + "-" + d.slice(9, 11)
        );
      return raw;
    }

    phoneInput?.addEventListener("blur", () => {
      phoneInput.value = normalizePhone(phoneInput.value);
    });

    // === Отправка ===
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (!(form instanceof HTMLFormElement)) return;

      const fd = new FormData(form);
      const payload = Object.fromEntries(fd.entries());
      if (payload.company) return; // honeypot

      const required = ["name", "phone", "role"];
      const missing = required.filter((f) => !payload[f] || String(payload[f]).trim() === "");

      form
        .querySelectorAll(".booking-modal__input, .booking-modal__select")
        .forEach((el) => el.classList.remove("is-error"));

      if (missing.length > 0) {
        required.forEach((key) => {
          const el = form.querySelector(`[name="${key}"]`);
          if (!payload[key] || String(payload[key]).trim() === "") {
            el?.classList.add("is-error");
          }
        });

        const msg = "Заполните обязательные поля.";
        showOverlayMessage(msg, "error", 2600);
        setFeedback(msg, "error");
        return;
      }

      try {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.setAttribute("disabled", "true");
          submitBtn.textContent = "Отправляем…";
        }

        await new Promise((r) => setTimeout(r, 400 + Math.random() * 300));

        const res = await fetch(WEBHOOK_URL, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            type: "vacancy",
            name: payload.name,
            phone: payload.phone,
            role: payload.role,
            message: payload.message || "",
            site: "https://relaxmassage51.ru",
          }),
        });

        if (res.ok) {
          const msg = "✅ Спасибо! Мы свяжемся с вами в ближайшее время.";
          showOverlayMessage(msg, "success", 2600);
          setFeedback("Спасибо! Мы свяжемся с вами в ближайшее время.", "success");
          form.reset();
          setTimeout(close, 2800);
        } else {
          const msg = "⚠️ Ошибка при отправке. Попробуйте позже.";
          showOverlayMessage(msg, "error", 2600);
          setFeedback(msg, "error");
        }
      } catch (err) {
        console.error(err);
        const msg = "❌ Ошибка соединения. Проверьте интернет.";
        showOverlayMessage(msg, "error", 2600);
        setFeedback(msg, "error");
      } finally {
        if (submitBtn instanceof HTMLButtonElement) {
          submitBtn.removeAttribute("disabled");
          submitBtn.textContent = defaultSubmitText;
        }
      }
    });
  })();
</script>
