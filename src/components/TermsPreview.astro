---
import Button from "@/components/Button.astro";
import "@/styles/terms-preview.css";
---

<section class="terms-preview" id="terms-preview" data-reveal-item>
  <div class="container">
    <header class="terms-head">
      <p class="eyebrow">Правила и политика</p>
      <h2 class="title">Условия предоставления услуг Relax For You</h2>
      <p class="subtitle">
        Ознакомьтесь с основными принципами обслуживания, конфиденциальности и бронирования — чтобы
        ваше пребывание было комфортным, безопасным и гармоничным
      </p>
    </header>

    <div class="terms-preview__cta">
      <Button
        text="Правила оказания услуг"
        href="/terms"
        variant="outline"
        size="md"
        class="terms-btn"
      />
    </div>
  </div>
</section>
