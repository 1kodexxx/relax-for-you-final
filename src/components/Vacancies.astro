---
import "@/styles/vacancies.css";
---

<section id="vacancies" class="vacancies">
  <div class="container">
    <!-- 🌸 Шапка блока -->
    <header class="vac-head" data-reveal-item>
      <p class="eyebrow">Команда Гармонии СПА</p>
      <h2 class="title">Вакансии для желающих быть в сфере массажного искусства</h2>
      <p class="subtitle">
        Мы ищем талантливых, энергичных, целеустремлённых людей в нашу компанию. Приглашаем как
        профессиональных мастеров с опытом, так и новичков с нуля. Главное — это желание
        развиваться, и мы создадим для вас лучшие условия. Добро пожаловать в коллектив!
      </p>
    </header>

    <!-- 💼 Кого ищем -->
    <div class="vac-grid" data-reveal-group data-stagger="120">
      <article class="vac-card" data-reveal-item>
        <h3 class="vac-card__title">Администратор (менеджер)</h3>
        <ul class="vac-list">
          <li>Опыт работы: от 3 лет</li>
          <li>
            Требования: cтрессоустойчивость, коммуникабельность, добросовестность, активность,
            вовлечённость
          </li>
          <li>Обязанности: консультация клиентов, оформление записей, ведение социальных сетей</li>
          <li>Зарплата: от 60 000 ₽</li>
          <li>Возможна удалённая работа</li>
        </ul>
      </article>

      <article class="vac-card" data-reveal-item>
        <h3 class="vac-card__title">Мастер массажа и SPA-процедур</h3>
        <ul class="vac-list">
          <li>Опыт работы: от 1 года / без опыта</li>
          <li>
            Требования: пунктуальность, компетентность, стрессоустойчивость, чистоплотность,
            обучаемость
          </li>
          <li>
            Обязанности: выполнение услуг по прайсу, консультация гостей, поддержание порядка на
            рабочем месте
          </li>
          <li>Зарплата: от 120 000 ₽</li>
        </ul>
      </article>

      <article class="vac-card" data-reveal-item>
        <h3 class="vac-card__title">Управляющий руководитель</h3>
        <ul class="vac-list">
          <li>Опыт работы: от 3 лет</li>
          <li>
            Требования: профессиональность, коммуникабельность, авторитетность, компетентность,
            вежливость
          </li>
          <li>
            Обязанности: контроль качества услуг, найм персонала, управление рабочим процессом
          </li>
          <li>Зарплата: от 90 000 ₽</li>
        </ul>
      </article>
    </div>

    <!-- 🪷 Условия и формат -->
    <section class="vac-terms" aria-labelledby="vac-terms-h" data-reveal-group data-stagger="120">
      <h3 id="vac-terms-h" class="vac-terms__title" data-reveal-item>
        Условия и формат сотрудничества
      </h3>
      <div class="vac-terms__grid">
        <div class="term card-ghost" data-reveal-item>
          <button class="term__header" type="button">График</button>
          <div class="term__content">
            <p>
              Смены устанавливаются индивидуально по желанию сотрудников. Ты можешь создать для себя
              идеальный график работы. Главное, помни, что от количества рабочего времени зависит
              твой заработок.
            </p>
          </div>
        </div>

        <div class="term card-ghost" data-reveal-item>
          <button class="term__header" type="button">Доход</button>
          <div class="term__content">
            <p>
              Заработанная плата одна из самых высоких в сфере услуг. Выплачивается каждый день,
              после рабочей смены. Имеются постоянные бонусы, премии, подарки и другие системы
              поощрения.
            </p>
          </div>
        </div>

        <div class="term card-ghost" data-reveal-item>
          <button class="term__header" type="button">Атмосфера</button>
          <div class="term__content">
            <p>
              Мы знаем, насколько важно работать в чистоте и уюте. Поэтому мы предоставляем самые
              лучшие условия для наших людей. В нашем распоряжении 3 премиальных салона красоты и
              массажа. Попробуй однажды — и ты не захочешь с нами расставаться.
            </p>
          </div>
        </div>

        <div class="term card-ghost" data-reveal-item>
          <button class="term__header" type="button">Обучение</button>
          <div class="term__content">
            <p>
              Мы предоставляем бесплатное обучение на всех этапах сотрудничества. Постоянное
              повышение квалификации за счёт компании. Неважно, профессионал или новичок — наша
              команда даёт возможности, от которых сложно отказаться.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 💌 Как откликнуться -->
    <section class="vac-cta" data-reveal-group data-stagger="140">
      <div class="vac-cta__box" data-reveal-item>
        <div class="vac-cta__text">
          <h3>Хочу работать в Гармонии СПА</h3>
          <p class="muted">
            Если вы готовы находиться в лучшей компании и команде сферы МАССАЖА, то добро пожаловать
            в коллектив! Присылайте нам свои отклики с резюме, общими данными и фотографиями — мы
            ждём именно Вас!
          </p>
        </div>
        <div class="vac-cta__actions">
          <a class="btn-outline" href="#vacancy" data-scroll-to-contacts>Откликнуться</a>
        </div>
      </div>
    </section>

    <!-- 🔮 Анимации появления -->
    <script is:inline>
      (function () {
        var root = document.getElementById("vacancies");
        if (!root) return;

        try {
          document.documentElement.classList.add("rfy-armed");
        } catch (e) {}

        if (typeof window.IntersectionObserver !== "function") {
          root.querySelectorAll("[data-reveal-item]").forEach((el) => el.classList.add("in"));
          root.querySelectorAll("[data-reveal-group]").forEach((el) => el.classList.add("in"));
          return;
        }

        var io = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => {
              if (!en.isIntersecting) return;
              var el = en.target;
              var group = el.closest("[data-reveal-group]");
              if (group) {
                var items = group.querySelectorAll("[data-reveal-item]");
                var idx = Array.prototype.indexOf.call(items, el);
                var stagger = Number(group.getAttribute("data-stagger") || 120);
                el.style.setProperty("--i", String(idx));
                el.style.setProperty("--stagger", stagger + "ms");
              }
              el.classList.add("in");
              io.unobserve(el);
            });
          },
          { root: null, rootMargin: "-10% 0px -10% 0px", threshold: 0.12 }
        );

        root.querySelectorAll("[data-reveal-item]:not(.in)").forEach((t) => io.observe(t));
        window.addEventListener(
          "load",
          () => {
            root.querySelectorAll("[data-reveal-item]:not(.in)").forEach((t) => io.observe(t));
          },
          { once: true }
        );
      })();
    </script>

    <!-- 🪷 Аккордеон для блока "Условия" -->
    <script is:inline>
      (() => {
        const terms = document.querySelectorAll(".term");
        terms.forEach((term) => {
          const header = term.querySelector(".term__header");
          const content = term.querySelector(".term__content");
          if (!header || !content) return;

          // начальное состояние
          content.style.maxHeight = "0";
          content.style.overflow = "hidden";
          content.style.transition = "max-height 0.4s ease, opacity 0.4s ease";
          content.style.opacity = "0";

          header.addEventListener("click", () => {
            const isOpen = term.classList.toggle("open");
            if (isOpen) {
              content.style.maxHeight = content.scrollHeight + "px";
              content.style.opacity = "1";
            } else {
              content.style.maxHeight = "0";
              content.style.opacity = "0";
            }
          });
        });
      })();
    </script>

    <!-- 💫 Скролл к контактам -->
    <script is:inline>
      (() => {
        const btn = document.querySelector("[data-scroll-to-contacts]");
        if (!btn) return;
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const target = document.getElementById("contacts");
          const infoCard = target?.querySelector(".contacts-info");
          if (!target) return;
          target.scrollIntoView({ behavior: "smooth", block: "center" });
          if (infoCard) {
            infoCard.classList.add("highlight");
            setTimeout(() => infoCard.classList.remove("highlight"), 3000);
          }
          history.replaceState(null, "", "#contacts");
        });
      })();
    </script>
  </div>
</section>
