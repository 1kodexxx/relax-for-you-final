---
/**
 * 🌐 SEO для "Гармония СПА" — версия с упором на Яндекс
 * - meta keywords оставляем (Яндекс почти не учитывает, но не мешает)
 * - добавлены: yandex-verification, robots/noindex, hreflang, улучшенный OG/Twitter
 * - JSON-LD: два филиала (DaySpa), geo + часы, ссылки sameAs
 * - опционально: Яндекс.Метрика (через prop)
 */

export interface Props {
  title?: string;
  description?: string;
  image?: string;     // абсолютный или от корня
  url?: string;       // канонический URL страницы
  keywords?: string;
  robots?: string;    // напр. "index,follow" | "noindex,nofollow"
  locale?: string;    // "ru_RU"
  siteName?: string;  // "Гармония СПА"
  hreflang?: string;  // "ru"
  yandexVerification?: string; // код в Яндекс.Вебмастере
  yandexMetrikaId?: string;    // ID счётчика (например, "12345678")
}

const {
  title = "Гармония СПА — Авторские SPA-программы в Мурманске",
  description = "Авторские SPA-программы.",
  image = "/assets/og-default.jpg",
  url = "https://relaxmassage51.ru",
  keywords = "Гармония СПА, SPA",
  robots = "index,follow",
  locale = "ru_RU",
  siteName = "Гармония СПА",
  hreflang = "ru",
  yandexVerification,
  yandexMetrikaId,
} = Astro.props;

// Помощники для абсолютных ссылок в OG
const absolute = (p: string) => p?.startsWith("http") ? p : `${url.replace(/\/$/, "")}${p.startsWith("/") ? "" : "/"}${p}`;
const ogImage = absolute(image);
---

<!-- 🧭 Базовые мета -->
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="robots" content={robots} />
<link rel="canonical" href={url} />
<link rel="alternate" hreflang={hreflang} href={url} />

<!-- ✅ Верификация Яндекса (если передали код) -->
{yandexVerification && <meta name="yandex-verification" content={yandexVerification} />}

<!-- ⚙️ Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:secure_url" content={ogImage} />
<meta property="og:locale" content={locale} />

<!-- 🐦 Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- 🧩 JSON-LD: сеть из двух филиалов как DaySpa -->
<script type="application/ld+json" is:inline>
{JSON.stringify({
  "@context":"https://schema.org",
  "@graph":[
    {
      "@type":"DaySpa",
      "@id": `${url}#org`,
      "name":"Гармония СПА",
      "alternateName":"Гармония СПА",
      "url": url,
      "image": ogImage,
      "telephone":"+7-911-332-29-17",
      "priceRange":"₽₽₽",
      "sameAs":[
        "https://t.me/",
        "https://wa.me/79113322917"
      ]
    },
    {
      "@type":"DaySpa",
      "name":"Гармония СПА",
      "parentOrganization": {"@id": `${url}#org`},
      "url": url,
      "image": ogImage,
      "telephone":"+7-911-332-29-17",
      "address":{
        "@type":"PostalAddress",
        "streetAddress":"ул. Трудовых резервов, 9",
        "addressLocality":"Мурманск",
        "addressRegion":"Мурманская область",
        "postalCode":"183000",
        "addressCountry":"RU"
      },
      "geo":{
        "@type":"GeoCoordinates",
        "latitude": 68.96,
        "longitude": 33.08
      },
      "openingHoursSpecification":[{
        "@type":"OpeningHoursSpecification",
        "dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens":"12:00",
        "closes":"00:00"
      }]
    },
    {
      "@type":"DaySpa",
      "name":"Гармония СПА — Октябрьский район",
      "parentOrganization": {"@id": `${url}#org`},
      "url": url,
      "image": ogImage,
      "telephone":"+7-911-332-29-17",
      "address":{
        "@type":"PostalAddress",
        "streetAddress":"ул. Карла Маркса, 6/1",
        "addressLocality":"Мурманск",
        "addressRegion":"Мурманская область",
        "postalCode":"183000",
        "addressCountry":"RU"
      },
      "geo":{
        "@type":"GeoCoordinates",
        "latitude": 68.97,
        "longitude": 33.08
      },
      "openingHoursSpecification":[{
        "@type":"OpeningHoursSpecification",
        "dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens":"12:00",
        "closes":"00:00"
      }]
    }
  ]
}, null, 0)}
</script>

<!-- 🪩 Цветовая тема -->
<meta name="theme-color" content="#0e0a0b" />
<meta name="color-scheme" content="dark" />


